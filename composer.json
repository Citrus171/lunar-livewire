{
    "name": "lunarphp/livewire-starter-kit",
    "type": "project",
    "description": "Livewire starter kit for Lunar e-commerce.",
    "keywords": [
        "lunar",
        "ecommerce",
        "e-commerce",
        "livewire",
        "laravel"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "guzzlehttp/guzzle": "^7.2",
        "http-interop/http-factory-guzzle": "^1.2",
        "kalnoy/nestedset": "6.0.5",
        "laravel/framework": "^10.43|^11.0",
        "laravel/sanctum": "^3.3|^4.0",
        "laravel/tinker": "^2.8",
        "league/flysystem-aws-s3-v3": "^3.0",
        "lunarphp/lunar": "^1.0@beta",
        "lunarphp/stripe": "^1.0@beta",
        "lunarphp/table-rate-shipping": "^1.0@beta",
        "meilisearch/meilisearch-php": "^1.6",
        "predis/predis": "^2.2"
    },
    "require-dev": {
        "driftingly/rector-laravel": "^2.2",
        "fakerphp/faker": "^1.23",
        "larastan/larastan": "^3.9",
        "laravel/boost": "^2.4",
        "laravel/pint": "^1.29",
        "mockery/mockery": "^1.4.4",
        "nunomaduro/collision": "^7.0|^8.1",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-browser": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "pestphp/pest-plugin-type-coverage": "^4.0",
        "phpunit/phpunit": "^12.0",
        "rector/rector": "^2.3",
        "spatie/laravel-ignition": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ],
        "test:type-coverage": "pest --type-coverage --min=90",
        "format:changed": "pint --parallel --dirty",
        "test:lint:changed": "pint --parallel --dirty --test",
        "test:lint": [
            "pint --parallel --dirty --test",
            "rector --dry-run"
        ],
        "test:unit": "XDEBUG_MODE=\"coverage\" pest --parallel --coverage --min=80",
        "test:types": [
            "phpstan"
        ],
        "test": [
            "@test:type-coverage",
            "@test:unit",
            "@test:lint",
            "@test:types"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true,
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
